# Set these as Environment Variables in the Render dashboard
# (Render > your service > Environment) — do NOT commit real values.

# --- Gmail SMTP (OTP delivery) ---
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword

# --- WebAuthn (passkeys) — MUST match your live Render URL exactly ---
WEBAUTHN_RP_ID=your-app-name.onrender.com
WEBAUTHN_ORIGIN=https://your-app-name.onrender.com

# --- Database (optional but recommended — see note below) ---
# If unset, falls back to a local SQLite file, which Render's free-tier
# ephemeral disk will WIPE on every redeploy. Add a free Render Postgres
# instance and paste its "Internal Database URL" here to persist real data.
DATABASE_URL=postgresql://user:password@host:5432/dbname
